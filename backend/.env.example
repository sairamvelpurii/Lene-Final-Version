# Local development settings. Copy this file to backend/.env.
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value
JWT_SECRET_KEY=replace-with-another-long-random-value

# Local MongoDB. Replace this with your MongoDB Atlas URI in production.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ai_finance

# Comma-separated frontend URLs allowed to call the API.
FRONTEND_URL=http://localhost:5173

UPLOAD_DIR=uploads
ML_MODEL_PATH=../ml/artifacts/expense_forecast.pkl

# Optional: enables the AI chat assistant.
GROQ_API_KEY=
